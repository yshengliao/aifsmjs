{
  "name": "aifsmjs",
  "version": "0.5.0",
  "description": "Small, strict FSM library for deterministic, replayable state machines in any TypeScript/JS app — multi-step forms, checkout funnels, auth flows, tutorials, scene flow. Pure step() lifecycle, opt-in effects, inspect, replay, and a fast-check property-based testing adapter. Browser / Node / Bun / Deno / WebView / Worker friendly.",
  "keywords": [
    "fsm",
    "state-machine",
    "finite-state-machine",
    "game-state",
    "game-dev",
    "web-game",
    "pixijs",
    "svelte",
    "xstate-alternative",
    "ai-readable",
    "property-based-testing",
    "fast-check",
    "typescript",
    "esm"
  ],
  "author": "yshengliao",
  "license": "MIT",
  "homepage": "https://github.com/yshengliao/aifsmjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yshengliao/aifsmjs.git"
  },
  "bugs": {
    "url": "https://github.com/yshengliao/aifsmjs/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "import": "./dist/guards/index.js",
      "require": "./dist/guards/index.cjs"
    },
    "./effects": {
      "types": "./dist/effects/index.d.ts",
      "import": "./dist/effects/index.js",
      "require": "./dist/effects/index.cjs"
    },
    "./inspect": {
      "types": "./dist/inspect/index.d.ts",
      "import": "./dist/inspect/index.js",
      "require": "./dist/inspect/index.cjs"
    },
    "./replay": {
      "types": "./dist/replay/index.d.ts",
      "import": "./dist/replay/index.js",
      "require": "./dist/replay/index.cjs"
    },
    "./pbt": {
      "types": "./dist/pbt/index.d.ts",
      "import": "./dist/pbt/index.js",
      "require": "./dist/pbt/index.cjs"
    },
    "./timer": {
      "types": "./dist/timer/index.d.ts",
      "import": "./dist/timer/index.js",
      "require": "./dist/timer/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README_ZHTW.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "verify:exports": "node scripts/verify-exports.mjs",
    "check:size": "node scripts/check-size.mjs",
    "build:llms": "node scripts/build-llms-full.mjs",
    "verify:llms": "node scripts/build-llms-full.mjs --check",
    "coverage": "vitest run --coverage",
    "example:traffic-light": "tsx examples/01-traffic-light/index.ts",
    "example:approval": "tsx examples/02-approval-workflow/index.ts",
    "example:checkout-funnel": "tsx examples/03-checkout-funnel/index.ts",
    "example:form-wizard": "tsx examples/04-form-wizard/index.ts",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm coverage && pnpm build && pnpm verify:exports && pnpm verify:llms && pnpm check:size"
  },
  "peerDependencies": {
    "fast-check": "^3.20.0"
  },
  "peerDependenciesMeta": {
    "fast-check": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^3.20.0",
    "tsup": "^8.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "publishConfig": {
    "access": "public"
  }
}
